UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxx
# NC AI VARCO Art 이미지 생성 API (T-010). 값은 NC AI 콘솔에서 발급.
NC_VARCO_API_KEY=
# NC OpenAPI 인증 헤더 (기본 OPENAPI_KEY; 레거시 Bearer는 Authorization)
# NC_VARCO_AUTH_HEADER=OPENAPI_KEY
# 이미지(3D) 생성 엔드포인트. 미지정 시 openapi.ai.nc.com/3d/varco/v1/image-to-3d
NC_VARCO_API_URL=https://openapi.ai.nc.com/3d/varco/v1/image-to-3d
# 선택: 베이스 URL만 오버라이드 (NC_VARCO_API_URL 미설정 시 path와 조합)
# NC_VARCO_API_BASE=https://openapi.ai.nc.com
NC_VARCO_MODEL=
# 202 비동기 폴링 (T-010). 라이브 probe 시 poll URL 미포함 → 템플릿 필요 시 설정.
# NC_VARCO_POLL_INTERVAL=2
# NC_VARCO_POLL_TIMEOUT=120
# NC_VARCO_POLL_URL_TEMPLATE={base}/3d/varco/v1/requests/{job_id}
